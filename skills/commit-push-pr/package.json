{
  "name": "@zcaceres/skill-commit-push-pr",
  "version": "1.0.0",
  "description": "Commit conversation changes, push, and open a PR. Stack-aware — uses git stack submit on stacked branches, else gh pr create. Preserves the existing base branch.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "fetch-tools": "echo 'no bundled tools'",
    "build": "echo 'no build step'",
    "test": "echo 'no tests'"
  },
  "crossAgent": {
    "supports": [
      "claude"
    ],
    "requires": [
      "name",
      "description"
    ]
  },
  "files": [
    "SKILL.md",
    "scripts",
    "references",
    "assets",
    "agents",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "skill",
    "slash-command",
    "stacked-prs",
    "git",
    "github"
  ]
}
