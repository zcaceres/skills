{
  "name": "@zcaceres/skill-dont-read-dot-env",
  "version": "1.0.0",
  "description": "Claude Code PreToolUse hook that blocks Read, Bash, Grep, and Glob calls that touch .env files (allows .env.example / .env.sample / .env.template / .env.dist).",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/index.ts",
    "test": "bun test",
    "build:linux": "bun build scripts/index.ts --compile --target=bun-linux-x64 --outfile scripts/bin/dont-read-dot-env-linux-x64",
    "build:macos": "bun build scripts/index.ts --compile --target=bun-darwin-arm64 --outfile scripts/bin/dont-read-dot-env-darwin-arm64",
    "build:windows": "bun build scripts/index.ts --compile --target=bun-windows-x64 --outfile scripts/bin/dont-read-dot-env-windows-x64.exe",
    "build:all": "bun run build:linux && bun run build:macos && bun run build:windows",
    "fetch-tools": "bun run build:all"
  },
  "files": [
    "SKILL.md",
    "scripts",
    "references",
    "assets",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "skill",
    "hook",
    "safety",
    "secrets",
    "dotenv",
    "pretooluse"
  ]
}
